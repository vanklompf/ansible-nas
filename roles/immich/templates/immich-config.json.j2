{
  "oauth": {
    "enabled": true,
    "issuerUrl": {{ immich_oidc_issuer_url | to_json }},
    "clientId": {{ immich_hostname | to_json }},
    "clientSecret": {{ immich_oidc_client_secret_effective | to_json }},
    "scope": "openid email profile",
    "buttonText": {{ ('Sign in with ' ~ oidc_provider_name) | to_json }},
    "autoRegister": true,
    "autoLaunch": {{ (immich_oidc_auto_login | bool) | to_json }},
    "signingAlgorithm": "RS256",
    "storageLabelClaim": "preferred_username",
    "mobileOverrideEnabled": false,
    "mobileRedirectUri": ""
  }
}
