# Managed by ansible-nas. Do not edit on the host.
version: 1
metadata:
  name: {{ (_authentik_app_blueprint_slug ~ ' OIDC') | to_json }}
  labels:
    blueprints.goauthentik.io/instantiate: "true"
entries:
  - model: authentik_providers_oauth2.oauth2provider
    id: {{ _authentik_app_blueprint_slug }}-provider
    identifiers:
      name: {{ _authentik_app_blueprint_slug | to_json }}
    attrs:
      name: {{ _authentik_app_blueprint_slug | to_json }}
      client_type: confidential
      client_id: {{ _authentik_app_blueprint_slug | to_json }}
      client_secret: {{ _authentik_app_blueprint_client_secret | to_json }}
      grant_types:
{% for grant_type in authentik_blueprint_oauth2_grant_types %}
        - {{ grant_type | to_json }}
{% endfor %}
      redirect_uris:
{% for redirect_uri in _authentik_app_blueprint_redirect_uris %}
        - matching_mode: strict
          url: {{ redirect_uri | to_json }}
{% endfor %}
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, authentik Self-signed Certificate]]
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]

  - model: authentik_core.application
    identifiers:
      slug: {{ _authentik_app_blueprint_slug | to_json }}
    attrs:
      name: {{ _authentik_app_blueprint_slug | to_json }}
      slug: {{ _authentik_app_blueprint_slug | to_json }}
      provider: !KeyOf {{ _authentik_app_blueprint_slug }}-provider
      meta_launch_url: {{ _authentik_app_blueprint_launch_url | to_json }}
      policy_engine_mode: any
